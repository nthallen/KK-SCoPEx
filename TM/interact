  case `hostname` in
    easwhlpt3425080)
      propmtrdev=
      slcandev=/dev/ttyS5;;
    *)
      propmtrdev=/dev/ttyUSB0
      slcandev=/dev/tty/ACM0;;
  esac
  
  Launch      memo   memo -o $Experiment.log -l4 -v
              [ -z "$launch_err" ] &&
                msg "Running script interact"
# Launch      -      subbusd_slcan -n CAN -p $slcandev -v
  Launch      tm_bfr bfr -s Both
  Launch      -TMC-  lgr -N `mlf_find LOG` -n lgr
  Launch Debug     tm_gen scopexcol
  Launch Debug cmd    scopexsrvr -s Unix -v
  Launch      -      tmdf
  [ -n "$propmtrdev" ] &&
  Launch      -      PropMtr -p $propmtrdev
  Launch      -TMC-  scopexalgo
